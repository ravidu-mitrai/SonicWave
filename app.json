{
  "expo": {
    "name": "SonicWave",
    "slug": "SonicWave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash.png",
    "scheme": "sonicwave",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#020A1C",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#020A1C"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "permissions": [
        "WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash.png",
        "backgroundColor": "#020A1C"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.SonicWave"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-audio"],
    "experiments": {
      "typedRoutes": true
    }
  }
}

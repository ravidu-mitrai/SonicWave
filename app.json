{
  "expo": {
    "name": "SonicWave",
    "slug": "SonicWave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash.jpg",
    "scheme": "sonicwave",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0F0F0F",
    "splash": {
      "image": "./assets/images/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "audio"
        ]
      },
      "bundleIdentifier": "com.anonymous.SonicWave"
    },
    "android": {
      "permissions": [
        "WAKE_LOCK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash.jpg",
        "backgroundColor": "#0F0F0F"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.SonicWave"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-audio",
        {
          "supportsBackgroundPlayback": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}